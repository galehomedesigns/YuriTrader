# === Secrets — never commit ===
.env
.env.local
.env.*.local
.env.save
.env.bak
*.key
*.pem
*-credentials.json
**/credentials.json
**/auth-profiles.json
.claude/settings.local.json

# === Runtime state (don't commit) ===
state/
logs/
memory/
.venv/

# === Personal / financial data + local data stores (never commit) ===
# workspace/ holds the expense ledger (Expenses_<year>.xlsx) and incoming
# receipt images — financial PII that must not enter version control.
workspace/
*.xlsx
*.xls
*.csv
# Local data stores (SQLite) — e.g. concierge_state.db (chat IDs, trade state)
*.db
*.sqlite
*.sqlite3

# === Binaries (vendored, not source) ===
bin/caddy

# === Build artifacts ===
__pycache__/
**/__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
node_modules/
**/node_modules/
build/
dist/

# === Misc ===
*.bak
*.bak.*
*.log
.DS_Store

# VPS-side env staging (holds the VPS OpenClaw bot token)
.vps.env
